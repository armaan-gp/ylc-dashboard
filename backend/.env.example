# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
APP_PASSWORD_HASH=$2b$12$your-bcrypt-hash-here

# SQLite for local dev; use PostgreSQL URL for production
DATABASE_URL=sqlite:///./ylc.db
